<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.proyectofinal.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_mainMenuFragment"
            app:destination="@id/mainMenuFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.proyectofinal.ui.auth.RegisterFragment"
        android:label="Registro"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/mainMenuFragment"
        android:name="com.example.proyectofinal.ui.menu.MainMenuFragment"
        android:label="Menú Principal"
        tools:layout="@layout/fragment_main_menu">
        <action
            android:id="@+id/action_mainMenuFragment_to_inventoryFragment"
            app:destination="@id/inventoryFragment" />
        <action
            android:id="@+id/action_mainMenuFragment_to_salesFragment"
            app:destination="@id/salesFragment" />
        <action
            android:id="@+id/action_mainMenuFragment_to_reportsFragment"
            app:destination="@id/reportsFragment" />
        <action
            android:id="@+id/action_mainMenuFragment_to_statisticsFragment"
            app:destination="@id/statisticsFragment" />
        <action
            android:id="@+id/action_mainMenuFragment_to_usersFragment"
            app:destination="@id/usersFragment" />
        <action
            android:id="@+id/action_mainMenuFragment_to_addProductFragment"
            app:destination="@id/addProductFragment" />
    </fragment>

    <fragment
        android:id="@+id/inventoryFragment"
        android:name="com.example.proyectofinal.ui.inventory.InventoryFragment"
        android:label="Inventario"
        tools:layout="@layout/fragment_inventory">
        <action
            android:id="@+id/action_inventoryFragment_to_addProductFragment"
            app:destination="@id/addProductFragment" />
    </fragment>

    <fragment
        android:id="@+id/addProductFragment"
        android:name="com.example.proyectofinal.ui.inventory.AddProductFragment"
        android:label="Nuevo Producto"
        tools:layout="@layout/fragment_add_product" />

    <fragment
        android:id="@+id/salesFragment"
        android:name="com.example.proyectofinal.ui.sales.SalesFragment"
        android:label="Ventas"
        tools:layout="@layout/fragment_sales" />

    <fragment
        android:id="@+id/reportsFragment"
        android:name="com.example.proyectofinal.ui.reports.ReportsFragment"
        android:label="Reportes"
        tools:layout="@layout/fragment_reports" />

    <fragment
        android:id="@+id/statisticsFragment"
        android:name="com.example.proyectofinal.ui.stats.StatisticsFragment"
        android:label="Estadísticas"
        tools:layout="@layout/fragment_statistics" />

    <fragment
        android:id="@+id/usersFragment"
        android:name="com.example.proyectofinal.ui.users.UsersFragment"
        android:label="Usuarios"
        tools:layout="@layout/fragment_users">
        <action
            android:id="@+id/action_usersFragment_to_addUserFragment"
            app:destination="@id/addUserFragment" />
    </fragment>

    <fragment
        android:id="@+id/addUserFragment"
        android:name="com.example.proyectofinal.ui.users.AddUserFragment"
        android:label="Nuevo Usuario"
        tools:layout="@layout/fragment_add_user" />

</navigation>